generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending
  paid
  failed
  cancelled
}

enum PaymentSource {
  return
  callback
  query
  system
}

model Customer {
  id                    String                @id @default(cuid())
  name                  String
  email                 String
  phone                 String
  lineId                String?
  orders                Order[]
  entitlements          Entitlement[]
  workbookEntries       WorkbookEntry[]
  quizResults           QuizResult[]
  threeMinuteCheckIns   ThreeMinuteCheckIn[]
  cravingTriggerEntries CravingTriggerEntry[]
  drinkResetEntries     DrinkResetEntry[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([email])
}

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  price       Int
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id                    String                @id @default(cuid())
  orderNo               String                @unique @db.VarChar(25)
  customerId            String
  customer              Customer              @relation(fields: [customerId], references: [id])
  amount                Int
  status                OrderStatus           @default(pending)
  buyerMemo             String                @db.VarChar(500)
  gomypayOrderId        String?
  avcode                String?
  cardLastNum           String?
  rawReturnPayload      Json?
  rawCallbackPayload    Json?
  paidAt                DateTime?
  items                 OrderItem[]
  entitlements          Entitlement[]
  workbookEntries       WorkbookEntry[]
  quizResults           QuizResult[]
  threeMinuteCheckIns   ThreeMinuteCheckIn[]
  cravingTriggerEntries CravingTriggerEntry[]
  drinkResetEntries     DrinkResetEntry[]
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([customerId])
  @@index([status, createdAt])
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productCode String
  name        String
  price       Int
  quantity    Int    @default(1)

  @@index([orderId])
}

model Entitlement {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  productCode String
  // 每筆訂單只有第一筆 entitlement 持有 canonical access token。
  accessToken String?  @unique
  downloadUrl String
  createdAt   DateTime @default(now())

  @@unique([orderId, productCode])
  @@index([customerId])
}

model PaymentLog {
  id         String        @id @default(cuid())
  orderNo    String
  source     PaymentSource
  payload    Json
  isVerified Boolean
  message    String
  createdAt  DateTime      @default(now())

  @@index([orderNo, createdAt])
}

model EmailLog {
  id           String    @id @default(cuid())
  to           String
  subject      String
  body         String
  status       String
  errorMessage String?
  createdAt    DateTime  @default(now())
  sentAt       DateTime?
}

model RateLimitEntry {
  key         String   @id
  count       Int      @default(1)
  windowStart DateTime @default(now())
}

model WorkbookEntry {
  id          String    @id @default(cuid())
  accessToken String
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  orderId     String?
  order       Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dayNumber   Int
  data        Json
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([accessToken, dayNumber])
  @@index([orderId])
  @@index([customerId])
}

model QuizResult {
  id            String    @id @default(cuid())
  accessToken   String
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  quizType      String
  answers       Json
  scores        Json
  primaryType   String
  secondaryType String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([accessToken, quizType])
  @@index([customerId])
  @@index([orderId])
}

model ThreeMinuteCheckIn {
  id                String    @id @default(cuid())
  accessToken       String
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])
  orderId           String?
  order             Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cravingItem       String?
  location          String?
  beforeActivity    String?
  bodySignals       Json?
  hungerScore       Int
  mouthCravingScore Int
  fatigueScore      Int
  stressScore       Int
  comfortNeedScore  Int
  sugaryDrinkScore  Int
  emotionTags       Json
  needType          String?
  chosenAction      String?
  cravingChange     String?
  finalChoice       String?
  selfReminder      String?
  resultType        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([accessToken, createdAt])
  @@index([customerId])
  @@index([orderId])
}

model CravingTriggerEntry {
  id             String    @id @default(cuid())
  accessToken    String
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  orderId        String?
  order          Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  occurredAt     DateTime?
  location       String?
  cravingItem    String?
  cravingScore   Int?
  hungerScore    Int?
  stressScore    Int?
  fatigueScore   Int?
  didEatOrDrink  Boolean?
  consumedItem   String?
  afterFeeling   Json?
  beforeActivity String?
  beforeEvent    String?
  beforeEmotion  String?
  bodyState      String?
  lastMealTime   String?
  lastMealEnough String?
  waterEnough    String?
  sleepPoor      Boolean?
  triggerTypes   Json?
  mainTrigger    String?
  notes          String?
  nextStrategy   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([accessToken, createdAt])
  @@index([customerId])
  @@index([orderId])
}

model DrinkResetEntry {
  id          String    @id @default(cuid())
  accessToken String
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  orderId     String?
  order       Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dayNumber   Int
  data        Json
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([accessToken, dayNumber])
  @@index([customerId])
  @@index([orderId])
}
