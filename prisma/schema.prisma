generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending
  paid
  failed
  cancelled
}

enum PaymentSource {
  return
  callback
  query
  system
}

model Customer {
  id                      String                  @id @default(cuid())
  name                    String
  email                   String
  phone                   String
  lineId                  String?
  orders                  Order[]
  entitlements            Entitlement[]
  workbookEntries         WorkbookEntry[]
  quizResults             QuizResult[]
  threeMinuteCheckIns     ThreeMinuteCheckIn[]
  cravingTriggerEntries   CravingTriggerEntry[]
  drinkResetEntries       DrinkResetEntry[]
  mindfulNutritionEntries MindfulNutritionEntry[]
  cravingRescueSessions   CravingRescueSession[]
  dinnerFormulaEntries    DinnerFormulaEntry[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([email])
}

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  price       Int
  description String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id                      String                  @id @default(cuid())
  orderNo                 String                  @unique @db.VarChar(25)
  customerId              String
  customer                Customer                @relation(fields: [customerId], references: [id])
  amount                  Int
  status                  OrderStatus             @default(pending)
  buyerMemo               String                  @db.VarChar(500)
  gomypayOrderId          String?
  avcode                  String?
  cardLastNum             String?
  rawReturnPayload        Json?
  rawCallbackPayload      Json?
  paidAt                  DateTime?
  items                   OrderItem[]
  entitlements            Entitlement[]
  workbookEntries         WorkbookEntry[]
  quizResults             QuizResult[]
  threeMinuteCheckIns     ThreeMinuteCheckIn[]
  cravingTriggerEntries   CravingTriggerEntry[]
  drinkResetEntries       DrinkResetEntry[]
  mindfulNutritionEntries MindfulNutritionEntry[]
  cravingRescueSessions   CravingRescueSession[]
  dinnerFormulaEntries    DinnerFormulaEntry[]
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([customerId])
  @@index([status, createdAt])
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productCode String
  name        String
  price       Int
  quantity    Int    @default(1)

  @@index([orderId])
}

model Entitlement {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  productCode String
  // 每筆訂單只有第一筆 entitlement 持有 canonical access token。
  accessToken String?  @unique
  downloadUrl String
  createdAt   DateTime @default(now())

  @@unique([orderId, productCode])
  @@index([customerId])
}

model PaymentLog {
  id         String        @id @default(cuid())
  orderNo    String
  source     PaymentSource
  payload    Json
  isVerified Boolean
  message    String
  createdAt  DateTime      @default(now())

  @@index([orderNo, createdAt])
}

model EmailLog {
  id           String    @id @default(cuid())
  to           String
  subject      String
  body         String
  status       String
  errorMessage String?
  createdAt    DateTime  @default(now())
  sentAt       DateTime?
}

model RateLimitEntry {
  key         String   @id
  count       Int      @default(1)
  windowStart DateTime @default(now())
}

model WorkbookEntry {
  id          String    @id @default(cuid())
  accessToken String
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  orderId     String?
  order       Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dayNumber   Int
  data        Json
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([accessToken, dayNumber])
  @@index([orderId])
  @@index([customerId])
}

model QuizResult {
  id            String    @id @default(cuid())
  accessToken   String
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  quizType      String
  answers       Json
  scores        Json
  primaryType   String
  secondaryType String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([accessToken, quizType])
  @@index([customerId])
  @@index([orderId])
}

model ThreeMinuteCheckIn {
  id                String    @id @default(cuid())
  accessToken       String
  customerId        String?
  customer          Customer? @relation(fields: [customerId], references: [id])
  orderId           String?
  order             Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  cravingItem       String?
  location          String?
  beforeActivity    String?
  bodySignals       Json?
  hungerScore       Int
  mouthCravingScore Int
  fatigueScore      Int
  stressScore       Int
  comfortNeedScore  Int
  sugaryDrinkScore  Int
  emotionTags       Json
  needType          String?
  chosenAction      String?
  cravingChange     String?
  finalChoice       String?
  selfReminder      String?
  resultType        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([accessToken, createdAt])
  @@index([customerId])
  @@index([orderId])
}

model CravingTriggerEntry {
  id             String    @id @default(cuid())
  accessToken    String
  customerId     String?
  customer       Customer? @relation(fields: [customerId], references: [id])
  orderId        String?
  order          Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  occurredAt     DateTime?
  location       String?
  cravingItem    String?
  cravingScore   Int?
  hungerScore    Int?
  stressScore    Int?
  fatigueScore   Int?
  didEatOrDrink  Boolean?
  consumedItem   String?
  afterFeeling   Json?
  beforeActivity String?
  beforeEvent    String?
  beforeEmotion  String?
  bodyState      String?
  lastMealTime   String?
  lastMealEnough String?
  waterEnough    String?
  sleepPoor      Boolean?
  triggerTypes   Json?
  mainTrigger    String?
  notes          String?
  nextStrategy   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([accessToken, createdAt])
  @@index([customerId])
  @@index([orderId])
}

model DrinkResetEntry {
  id          String    @id @default(cuid())
  accessToken String
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  orderId     String?
  order       Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dayNumber   Int
  data        Json
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([accessToken, dayNumber])
  @@index([customerId])
  @@index([orderId])
}

model MindfulNutritionEntry {
  id          String    @id @default(cuid())
  accessToken String
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  orderId     String?
  order       Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dayNumber   Int
  data        Json
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([accessToken, dayNumber])
  @@index([customerId])
  @@index([orderId])
}

model CravingRescueSession {
  id              String    @id @default(cuid())
  accessToken     String
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  orderId         String?
  order           Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  desiredItem     String?
  initialCraving  Int
  initialHunger   Int
  initialStress   Int
  initialFatigue  Int
  primaryStates   Json
  selectedActions Json
  finalCraving    Int?
  consumedResult  String?
  finalChoice     String?
  helpfulness     String?
  reminderNote    String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  createdAt       DateTime  @default(now())

  @@index([accessToken, createdAt])
  @@index([customerId])
  @@index([orderId])
}

model DinnerFormulaEntry {
  id                  String    @id @default(cuid())
  accessToken         String
  customerId          String?
  customer            Customer? @relation(fields: [customerId], references: [id])
  orderId             String?
  order               Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  hungerScore         Int
  fatigueScore        Int
  stressScore         Int
  currentStates       Json
  mealScene           String
  proteinChoice       String
  vegetableChoice     String
  carbChoice          String
  drinkChoice         String
  closingAction       String
  generatedSuggestion String
  daytimeIntakeStatus String?
  dinnerTimeBand      String?
  tonightConcerns     Json?
  contextData         Json?
  dinnerFormulaResult Json?
  fullnessAfterDinner Int?
  cravingAfterDinner  String?
  hadSweetDrink       Boolean?
  didClosingAction    String?
  reflection          String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([accessToken, createdAt])
  @@index([customerId])
  @@index([orderId])
}

model SafeSwapRecord {
  id                 String   @id @default(cuid())
  accessToken        String
  cravingCategory    String
  originalChoice     String
  cravingIntensity   Int
  recommendedOptions Json
  createdAt          DateTime @default(now())

  @@index([accessToken, createdAt])
}

model SafeSwapFavorite {
  id               String   @id @default(cuid())
  accessToken      String
  favoriteCategory String
  title            String
  content          String
  createdAt        DateTime @default(now())

  @@index([accessToken, createdAt])
}

model DrinkSwapProRecord {
  id              String   @id @default(cuid())
  accessToken     String
  category        String
  originalChoice  String
  sugarHabit      String
  toppingsHabit   Json
  cupSize         String
  suggestedSwap   String
  suggestedReason String
  orderScript     String
  nextStep        String
  drinkId         String?
  feeling         String?
  context         String?
  analysisResult  Json?
  createdAt       DateTime @default(now())

  @@index([accessToken, createdAt])
}

model DrinkSwapProFavorite {
  id               String   @id @default(cuid())
  accessToken      String
  favoriteCategory String
  title            String
  content          String
  orderScript      String
  drinkId          String?
  context          String?
  originalVersion  String?
  currentVersion   String?
  note              String?
  createdAt        DateTime @default(now())

  @@index([accessToken, createdAt])
}

model DrinkSwapProProfile {
  id          String   @id @default(cuid())
  accessToken String   @unique
  rules       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model DrinkSwapProObservation {
  id          String   @id @default(cuid())
  accessToken String
  dayNumber   Int
  time        String
  feeling     String
  version     String
  reflection  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([accessToken, dayNumber])
  @@index([accessToken, createdAt])
}

model EatingOutMenuLog {
  id                      String   @id @default(cuid())
  accessToken             String
  dayNumber               Int
  eatingOutScene          String
  currentStates           Json
  recommendedMeal         Json
  dinnerSatisfactionScore Int?
  afterDinnerCravingScore Int?
  hadSugaryDrink          Boolean?
  didClosingRoutine       Boolean?
  mainAdjustmentNeeded    String?
  notes                   String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([accessToken, createdAt])
}

model EatingOutMenuFavorite {
  id             String   @id @default(cuid())
  accessToken    String
  title          String
  scene          String
  mealContent    String
  closingRoutine String
  createdAt      DateTime @default(now())

  @@index([accessToken, createdAt])
}

model EatingNavigationSession {
  id                    String   @id @default(cuid())
  accessToken           String
  customerId            String?
  orderId               String?
  statusScan             Json
  navigationModes        Json
  sceneId                String
  selectedItems          Json
  analysisResult         Json
  threeRouteSuggestions  Json
  finalSelectedItems     Json?
  postMealReview         Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  @@index([accessToken, createdAt])
}

model EatingNavigationFavorite {
  id          String   @id @default(cuid())
  accessToken String
  title       String
  sceneId     String
  items       Json
  tags        Json
  score       Int
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([accessToken, sceneId, createdAt])
}

model BreakthroughPlanProgress {
  id               String   @id @default(cuid())
  accessToken      String   @unique
  currentLevel     Int      @default(1)
  completedLevels  Json
  collectedClues   Json
  earnedBadges     Json
  actionPoints     Int      @default(0)
  primaryType      String?
  secondaryType    String?
  recommendedRoute String?
  selectedBranch   String?
  characterCreated Boolean  @default(false)
  characterCreatedAt DateTime?
  selectedGender   String?
  primaryCharacterName String?
  primaryOriginalTypeName String?
  secondaryCharacterName String?
  secondaryOriginalTypeName String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BreakthroughDailyEntry {
  id                 String    @id @default(cuid())
  accessToken        String
  levelNumber        Int
  levelName          String
  taskName           String
  selectedTool       String
  completed          Boolean   @default(false)
  collectedClue      Json
  earnedBadge        String
  actionPointsEarned Int       @default(0)
  userNotes          String?
  selectedBranch     String?
  userInputs         Json?
  analysisResult     Json?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([accessToken, levelNumber])
  @@index([accessToken])
}

model PersonalRescueMap {
  id                   String   @id @default(cuid())
  accessToken          String   @unique
  primaryType          String
  secondaryType        String?
  recommendedRoute     String
  highRiskTime         String?
  highRiskScene        String?
  mainEmotion          String?
  nutritionGap         String?
  highRiskDrinkOrSnack String?
  safeSwapOptions      Json
  dinnerBackups        Json
  rescuePlan           String?
  nextWeekAction       String?
  primaryCharacterName String?
  primaryOriginalTypeName String?
  secondaryCharacterName String?
  secondaryOriginalTypeName String?
  bodySignal           String?
  selectedBranch       String?
  firstRescueAction    String?
  rewardUnlocked       Boolean  @default(false)
  rewardUnlockedAt     DateTime?
  generatedAt          DateTime @default(now())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}
